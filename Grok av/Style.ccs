<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D¥I\[ Y FLY</title>
    <link rel="stylesheet" href="style.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Orbitron:wght@400;700&display=swap');
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading-screen" class="loading-screen">
        <div class="logo-container">
            <div class="logo">D¥I \]Y FLY</div>
            <div class="tagline">FLY HIGH. TIME YOUR EXIT.</div>
            <div class="jet-loader">✈️</div>
        </div>
    </div>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Header -->
        <header class="header">
            <div class="header-left">
                <div class="logo-main">D¥I$$Y FLY</div>
            </div>
            
            <div class="header-center">
                <button id="history-btn" class="history-btn">HISTORY</button>
            </div>
            
            <div class="header-right">
                <div class="balance">
                    <span class="balance-label">BALANCE</span>
                    <span id="balance-amount" class="balance-value">KSH 15,000</span>
                </div>
                <button class="bonus-btn">BONUS</button>
                <div class="icons">
                    <button class="icon-btn">👤</button>
                    <button class="icon-btn">⚙️</button>
                </div>
            </div>
        </header>

        <!-- Game Area -->
        <div class="game-container">
            <!-- Canvas for Game Animation -->
            <div class="game-canvas-container">
                <canvas id="game-canvas" width="800" height="400"></canvas>
                
                <!-- Live Multiplier -->
                <div id="multiplier-display" class="multiplier-display">
                    <div class="multiplier-value" id="multiplier-value">1.00x</div>
                </div>
                
                <!-- Crash Message -->
                <div id="crash-message" class="crash-message hidden">
                    <div class="crash-text">CRASHED AT</div>
                    <div id="crash-value" class="crash-value">7.45x</div>
                </div>
            </div>
        </div>

        <!-- Betting Panels -->
        <div class="betting-section">
            <!-- Bet Panel 1 -->
            <div class="bet-panel">
                <div class="bet-header">BET 1</div>
                <div class="stake-input">
                    <button class="adjust-btn" id="bet1-minus">-</button>
                    <input type="number" id="bet1-stake" value="100" min="10" max="20000">
                    <button class="adjust-btn" id="bet1-plus">+</button>
                </div>
                <div class="quick-actions">
                    <button class="quick-btn" onclick="adjustBet(1, 0.5)">½</button>
                    <button class="quick-btn" onclick="adjustBet(1, 2)">2×</button>
                    <button class="quick-btn" onclick="adjustBet(1, 'max')">MAX</button>
                </div>
                <button id="bet1-btn" class="bet-btn">BET KSH 100</button>
            </div>

            <!-- Bet Panel 2 -->
            <div class="bet-panel">
                <div class="bet-header">BET 2</div>
                <div class="stake-input">
                    <button class="adjust-btn" id="bet2-minus">-</button>
                    <input type="number" id="bet2-stake" value="200" min="10" max="20000">
                    <button class="adjust-btn" id="bet2-plus">+</button>
                </div>
                <div class="quick-actions">
                    <button class="quick-btn" onclick="adjustBet(2, 0.5)">½</button>
                    <button class="quick-btn" onclick="adjustBet(2, 2)">2×</button>
                    <button class="quick-btn" onclick="adjustBet(2, 'max')">MAX</button>
                </div>
                <button id="bet2-btn" class="bet-btn">BET KSH 200</button>
            </div>
        </div>

        <!-- Live Players -->
        <div class="live-players">
            <div class="section-title">LIVE ACTIVITY</div>
            <div id="players-list" class="players-list"></div>
        </div>

        <!-- Stats & Previous -->
        <div class="bottom-section">
            <!-- Previous Rounds -->
            <div class="previous-rounds">
                <div class="section-title">PREVIOUS ROUNDS</div>
                <div id="previous-rounds" class="rounds-grid"></div>
            </div>
            
            <!-- Statistics -->
            <div class="stats-panel">
                <div class="section-title">STATS</div>
                <div class="stats-grid">
                    <div>ROUND: <span id="current-round">142</span></div>
                    <div>HIGH: <span id="high-today">87.45x</span></div>
                    <div>AVG: <span id="avg-multi">3.24x</span></div>
                    <div>PLAYERS: <span id="active-players">1247</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- History Modal -->
    <div id="history-modal" class="modal hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2>ROUND HISTORY</h2>
                <button onclick="closeModal()" class="close-btn">✕</button>
            </div>
            <div id="full-history" class="history-list"></div>
            <div class="history-summary">
                <div>Avg: <span id="modal-avg">4.12x</span></div>
                <div>High: <span id="modal-high">245.8x</span></div>
                <div>Low: <span id="modal-low">1.01x</span></div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>